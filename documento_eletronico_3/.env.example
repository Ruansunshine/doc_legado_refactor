# ============================================================
# Conecta SLZ - Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e configure as variaveis:
#   cp .env.example .env
# ============================================================

# --- BANCO DE DADOS (PostgreSQL) ---
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
# Exemplos:
#   Local:  postgresql://postgres:postgres@localhost:5432/conecta_slz?schema=public
#   Neon:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/conecta_slz?sslmode=require
#   Supabase: postgresql://postgres.xxx:pass@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:root@localhost:5432/conecta_slz?schema=public"

# --- SEGURANCA ---
# Chave secreta para assinatura de tokens JWT de sessao (mude em producao!)
SESSION_SECRET="mude-esta-chave-em-producao-use-algo-aleatorio-e-longo"
